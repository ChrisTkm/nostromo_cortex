# MongoDB connection URI for the MCP server, CLI scripts, and shared core config.
# Default: mongodb://127.0.0.1:27017
MONGO_URL=mongodb://127.0.0.1:27017

# MongoDB database name used by the MCP server and shared core config.
# Default: cortex
MONGO_DB_NAME=cortex

# MongoDB collection name used for Cortex tasks.
# Default: tasks
MONGO_TASKS_COLLECTION=tasks

# Telemetry storage backend. Use "sqlite" or "jsonl".
# Default: sqlite
TELEMETRY_BACKEND=sqlite

# SQLite telemetry database path.
# Default: ./data/telemetry/cortex-telemetry.db
TELEMETRY_SQLITE_PATH=./data/telemetry/cortex-telemetry.db

# JSONL telemetry output path when TELEMETRY_BACKEND=jsonl.
# Default: ./data/telemetry/cortex-telemetry.jsonl
TELEMETRY_JSONL_PATH=./data/telemetry/cortex-telemetry.jsonl

# Logger verbosity. Supported values: debug, info, warn, error.
# Default: info
LOG_LEVEL=info

# Logger output format. Use "pretty" or "json".
# Default: pretty
LOG_FORMAT=pretty

# Maximum number of tasks included in graph snapshots.
# Default: 500
SNAPSHOT_MAX_TASKS=500
