{
  "name": "cortex",
  "displayName": "Cortex",
  "publisher": "cortex-local",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "files": [
    "dist/**",
    "media/**",
    "package.json",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:cortex.overview",
    "onCommand:cortex.openGraph",
    "onCommand:cortex.openArchive",
    "onCommand:cortex.openBrain",
    "onCommand:cortex.openMdxGraph",
    "onCommand:cortex.openScriptFlow",
    "onCommand:cortex.openScriptFlowForSelection",
    "onCommand:cortex.archivePlan",
    "onCommand:cortex.setMongoUrl",
    "onCommand:cortex.clearMongoUrl"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cortex.refresh",
        "title": "Cortex: Refresh tasks"
      },
      {
        "command": "cortex.openTasks",
        "title": "Cortex: Focus task navigator"
      },
      {
        "command": "cortex.switchPanel",
        "title": "Cortex: Switch panel"
      },
      {
        "command": "cortex.openGraph",
        "title": "Cortex: Open PERT graph"
      },
      {
        "command": "cortex.togglePlanStatusFilter",
        "title": "Cortex: Toggle plan status filter",
        "icon": "$(filter)"
      },
      {
        "command": "cortex.showOptions",
        "title": "Cortex: Options"
      },
      {
        "command": "cortex.openNotes",
        "title": "Cortex: Open notes panel"
      },
      {
        "command": "cortex.openLogs",
        "title": "Cortex: Open logs panel"
      },
      {
        "command": "cortex.openArchive",
        "title": "Cortex: Open Archive"
      },
      {
        "command": "cortex.openBrain",
        "title": "Cortex: Open Brain"
      },
      {
        "command": "cortex.openMdxGraph",
        "title": "Cortex: Open MD/MDX Graph"
      },
      {
        "command": "cortex.openScriptFlow",
        "title": "Cortex: Open Script Flow"
      },
      {
        "command": "cortex.openScriptFlowForSelection",
        "title": "Cortex: Open Script Flow for Selection"
      },
      {
        "command": "cortex.newNote",
        "title": "Cortex: New note"
      },
      {
        "command": "cortex.editNote",
        "title": "Cortex: Edit note"
      },
      {
        "command": "cortex.deleteNote",
        "title": "Cortex: Delete note"
      },
      {
        "command": "cortex.snoozeReminder",
        "title": "Cortex: Snooze reminder"
      },
      {
        "command": "cortex.setSearchQuery",
        "title": "Cortex: Set search query"
      },
      {
        "command": "cortex.setTagFilter",
        "title": "Cortex: Set tag filter"
      },
      {
        "command": "cortex.setProjectFilter",
        "title": "Cortex: Set project filter"
      },
      {
        "command": "cortex.setGroupFilter",
        "title": "Cortex: Set group filter"
      },
      {
        "command": "cortex.selectDatabase",
        "title": "Cortex: Select Mongo database"
      },
      {
        "command": "cortex.setMongoUrl",
        "title": "Cortex: Set Mongo URL"
      },
      {
        "command": "cortex.clearMongoUrl",
        "title": "Cortex: Clear Mongo URL"
      },
      {
        "command": "cortex.bootstrapDatabase",
        "title": "Cortex: Create sample local database"
      },
      {
        "command": "cortex.editTask",
        "title": "Cortex: Edit task"
      },
      {
        "command": "cortex.clearFilters",
        "title": "Cortex: Clear filters"
      },
      {
        "command": "cortex.selectPlan",
        "title": "Cortex: Select Action Plan"
      },
      {
        "command": "cortex.archivePlan",
        "title": "Cortex: Archive Plan"
      },
      {
        "command": "cortex.listCycles",
        "title": "Cortex: List dependency cycles"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cortex",
          "title": "Cortex",
          "icon": "media/cortex.svg"
        }
      ]
    },
    "views": {
      "cortex": [
        {
          "id": "cortex.overview",
          "name": "Task Navigator"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cortex.newNote",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "cortex.openNotes",
        "key": "ctrl+alt+shift+n",
        "mac": "cmd+alt+shift+n"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cortex.refresh",
          "when": "view == cortex.overview",
          "group": "navigation@1"
        },
        {
          "command": "cortex.switchPanel",
          "when": "view == cortex.overview",
          "group": "navigation@2"
        },
        {
          "command": "cortex.togglePlanStatusFilter",
          "when": "view == cortex.overview",
          "group": "navigation@3"
        },
        {
          "command": "cortex.showOptions",
          "when": "view == cortex.overview",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "cortex.editTask",
          "when": "view == cortex.overview && viewItem == cortex.task",
          "group": "inline@1"
        },
        {
          "command": "cortex.openGraph",
          "when": "view == cortex.overview && viewItem == cortex.task",
          "group": "inline@2"
        },
        {
          "command": "cortex.archivePlan",
          "when": "view == cortex.overview && viewItem == cortex.plan.done",
          "group": "inline@1"
        }
      ],
      "editor/context": [
        {
          "command": "cortex.openScriptFlow",
          "when": "editorTextFocus && (resourceExtname == .ts || resourceExtname == .tsx || resourceExtname == .py || resourceExtname == .sql)",
          "group": "navigation@10"
        },
        {
          "command": "cortex.openScriptFlowForSelection",
          "when": "editorTextFocus && editorHasSelection && (resourceExtname == .ts || resourceExtname == .tsx || resourceExtname == .py || resourceExtname == .sql)",
          "group": "navigation@11"
        }
      ]
    },
    "configuration": {
      "title": "Cortex",
      "properties": {
        "cortex.mongoUrl": {
          "type": "string",
          "default": "mongodb://127.0.0.1:27017",
          "description": "MongoDB connection string used by the extension host.",
          "deprecationMessage": "Use the 'Cortex: Set Mongo URL' command instead. The URL is now stored securely in VS Code SecretStorage."
        },
        "cortex.mongoDbName": {
          "type": "string",
          "default": "cortex",
          "description": "Mongo database name used for task storage."
        },
        "cortex.mongoTasksCollection": {
          "type": "string",
          "default": "tasks",
          "description": "Mongo collection name used for tasks."
        },
        "cortex.mongoNotesCollection": {
          "type": "string",
          "default": "notes",
          "description": "Colección de notas en Mongo."
        },
        "cortex.mongoLogsCollection": {
          "type": "string",
          "default": "logs",
          "description": "Colección de logs en Mongo."
        },
        "cortex.mongoPlansCollection": {
          "type": "string",
          "default": "action_plans",
          "description": "Colección de action_plans en Mongo"
        },
        "cortex.archivePath": {
          "type": "string",
          "default": "",
          "description": "Archive output directory. If empty, Cortex uses ~/cortex-archive."
        },
        "cortex.mdxGraphMaxFiles": {
          "type": "number",
          "default": 800,
          "minimum": 1,
          "description": "Maximum number of .md/.mdx files scanned by Cortex Brain."
        },
        "cortex.brainRootPath": {
          "type": "string",
          "default": "",
          "description": "Default local folder scanned by Cortex Brain. Leave empty to choose a folder when opening the panel."
        },
        "cortex.telemetryBackend": {
          "type": "string",
          "enum": [
            "sqlite",
            "jsonl"
          ],
          "default": "sqlite",
          "description": "Telemetry storage backend."
        },
        "cortex.telemetrySqlitePath": {
          "type": "string",
          "default": "./data/telemetry/cortex-telemetry.db",
          "description": "Local SQLite path for telemetry."
        }
      }
    }
  },
  "scripts": {
    "dev": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "package:vsix": "vsce package --no-dependencies --allow-missing-repository"
  },
  "dependencies": {
    "@cortex/core": "workspace:*",
    "@cortex/telemetry": "workspace:*",
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "html-to-image": "^1.11.13",
    "mongodb": "^6.16.0",
    "node-sql-parser": "^5.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.2",
    "tree-sitter-python": "^0.25.0"
  }
}
